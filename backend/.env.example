# ===========================================
# API Ophtha Kaizen - Variables de Entorno
# ===========================================

# Entorno: development | production
NODE_ENV=development

# ===========================================
# Base de Datos MySQL
# ===========================================
MYSQLDB_HOST=localhost
MYSQLDB_USER=root
MYSQLDB_ROOT_PASSWORD=your_root_password
MYSQLDB_PASSWORD=your_password
MYSQLDB_DATABASE=db_ophtha
DB_PORT=3306

# Docker ports
MYSQLDB_LOCAL_PORT=3307
MYSQLDB_DOCKER_PORT=3306

# ===========================================
# Servidor Node.js
# ===========================================
NODE_LOCAL_PORT=4001
NODE_DOCKER_PORT=4001

# ===========================================
# JWT Authentication
# ===========================================
SECRET=your_jwt_secret_key_here
SECRET_REFRESH=your_jwt_refresh_secret_key_here

# ===========================================
# Administrador por defecto
# ===========================================
ADMIN_EMAIL=admin@example.com
ADMIN_FIRSTH_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PASSWORD=your_admin_password

# ===========================================
# Email Configuration (Nodemailer)
# ===========================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SEND=noreply@example.com
EMAIL_PASS=your_email_password
EMAIL_ORDER_SEND=orders@example.com
